---
import "aos/dist/aos.css";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import { SITE, formattedAddress, socialLinks, whatsappUrl } from "../consts";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  robots?: string;
}

const {
  title = SITE.defaultTitle,
  description = SITE.defaultDescription,
  pathname = Astro.url.pathname,
  image = SITE.ogImage,
  robots = "index,follow",
} = Astro.props;

const canonical = new URL(pathname, SITE.siteUrl).toString();
const schema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: SITE.legalName,
  image,
  telephone: SITE.phone,
  servesCuisine: ["Mediterránea", "Cocina de autor"],
  priceRange: "€€€",
  url: canonical,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.streetAddress,
    addressLocality: SITE.address.locality,
    postalCode: SITE.address.postalCode,
    addressRegion: SITE.address.region,
    addressCountry: SITE.address.countryCode,
  },
  openingHoursSpecification: SITE.hours.map((slot) => ({
    "@type": "OpeningHoursSpecification",
    description: `${slot.label}: ${slot.value}`,
  })),
  sameAs: [SITE.menuUrl, whatsappUrl, ...socialLinks.map((link) => link.href)],
  areaServed: formattedAddress,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={SITE.legalName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <script>
      import AOS from "aos";
      import { inject } from "@vercel/analytics";

      type ConsentPreferences = {
        analytics: boolean;
        thirdParty: boolean;
      };

      declare global {
        interface Window {
          __mirabuenoAnalyticsLoaded?: boolean;
        }
      }

      const cookieConsentKey = "mirabueno-cookie-consent";

      const isPreferences = (value: unknown): value is ConsentPreferences => {
        if (!value || typeof value !== "object") {
          return false;
        }

        const candidate = value as Record<string, unknown>;
        return (
          typeof candidate.analytics === "boolean" &&
          typeof candidate.thirdParty === "boolean"
        );
      };

      const parseStoredConsent = (): ConsentPreferences | null => {
        const storedConsent = window.localStorage.getItem(cookieConsentKey);

        if (!storedConsent) {
          return null;
        }

        if (storedConsent === "accepted") {
          return { analytics: true, thirdParty: true };
        }

        if (storedConsent === "rejected") {
          return { analytics: false, thirdParty: false };
        }

        try {
          const parsed = JSON.parse(storedConsent) as unknown;
          return isPreferences(parsed) ? parsed : null;
        } catch {
          return null;
        }
      };

      const dispatchConsent = (preferences: ConsentPreferences | null) => {
        window.dispatchEvent(
          new CustomEvent("mirabueno:cookie-consent", {
            detail: { preferences },
          }),
        );
      };

      const applyConsent = (preferences: ConsentPreferences | null) => {
        document.documentElement.dataset.cookieConsent = preferences
          ? "configured"
          : "pending";
        document.documentElement.dataset.cookieAnalytics =
          preferences?.analytics ? "accepted" : "rejected";
        document.documentElement.dataset.cookieThirdParty =
          preferences?.thirdParty ? "accepted" : "rejected";

        if (preferences?.analytics && !window.__mirabuenoAnalyticsLoaded) {
          inject();
          window.__mirabuenoAnalyticsLoaded = true;
        }

        dispatchConsent(preferences);
      };

      const initAos = () => {
        AOS.init({
          once: true,
          duration: 750,
          easing: "ease-out-cubic",
          offset: 80,
        });
      };

      applyConsent(parseStoredConsent());
      initAos();

      window.addEventListener(
        "mirabueno:set-cookie-consent",
        (event: Event) => {
          if (!(event instanceof CustomEvent)) {
            return;
          }

          const preferences = isPreferences(event.detail?.preferences)
            ? event.detail.preferences
            : null;

          if (!preferences) {
            return;
          }

          window.localStorage.setItem(
            cookieConsentKey,
            JSON.stringify(preferences),
          );
          applyConsent(preferences);
        },
      );

      window.addEventListener("mirabueno:open-cookie-settings", () => {
        document.documentElement.dataset.cookieConsent = "pending";
      });
    </script>
  </body>
</html>
