---
import "aos/dist/aos.css";
import CookieConsent from "../components/CookieConsent.astro";
import Analytics from "@vercel/analytics/astro";
import "../styles/global.css";

import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import { SITE, formattedAddress, whatsappUrl } from "../consts";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
}

const {
  title = SITE.defaultTitle,
  description = SITE.defaultDescription,
  pathname = Astro.url.pathname,
  image = SITE.ogImage,
} = Astro.props;

const canonical = new URL(pathname, SITE.siteUrl).toString();
const schema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: SITE.legalName,
  image,
  telephone: SITE.phone,
  servesCuisine: ["Mediterránea", "Cocina de autor"],
  priceRange: "€€€",
  url: canonical,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.streetAddress,
    addressLocality: SITE.address.locality,
    postalCode: SITE.address.postalCode,
    addressRegion: SITE.address.region,
    addressCountry: SITE.address.countryCode,
  },
  openingHoursSpecification: SITE.hours.map((slot) => ({
    "@type": "OpeningHoursSpecification",
    description: `${slot.label}: ${slot.value}`,
  })),
  sameAs: [SITE.menuUrl, whatsappUrl],
  areaServed: formattedAddress,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={SITE.legalName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <Analytics />

    <script>
      import AOS from "aos";
      import { inject } from "@vercel/analytics";

      type ConsentValue = "accepted" | "rejected" | null;

      declare global {
        interface Window {
          __mirabuenoAnalyticsLoaded?: boolean;
        }
      }

      const cookieConsentKey = "mirabueno-cookie-consent";

      const dispatchConsent = (value: ConsentValue) => {
        window.dispatchEvent(
          new CustomEvent("mirabueno:cookie-consent", {
            detail: { value },
          }),
        );
      };

      const applyConsent = (value: ConsentValue) => {
        document.documentElement.dataset.cookieConsent = value || "pending";

        if (value === "accepted" && !window.__mirabuenoAnalyticsLoaded) {
          inject();
          window.__mirabuenoAnalyticsLoaded = true;
        }

        dispatchConsent(value);
      };

      const initAos = () => {
        AOS.init({
          once: true,
          duration: 750,
          easing: "ease-out-cubic",
          offset: 80,
        });
      };

      const storedConsent = window.localStorage.getItem(cookieConsentKey);

      applyConsent((storedConsent as ConsentValue) ?? null);
      initAos();

      window.addEventListener(
        "mirabueno:set-cookie-consent",
        (event: Event) => {
          if (!(event instanceof CustomEvent)) {
            return;
          }

          const value =
            (event.detail?.value as ConsentValue | undefined) ?? null;

          if (value !== "accepted" && value !== "rejected") {
            return;
          }

          window.localStorage.setItem(cookieConsentKey, value);
          applyConsent(value);
        },
      );

      window.addEventListener("mirabueno:open-cookie-settings", () => {
        document.documentElement.dataset.cookieConsent = "pending";
      });
    </script>
  </body>
</html>
