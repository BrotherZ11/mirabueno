---
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, whatsappUrl } from "../consts";
---

<BaseLayout
  title="Reservas | Restaurante Venta Mirabueno Setenil de las Bodegas"
  description="Reserva tu mesa en Restaurante Venta Mirabueno por WhatsApp de forma rápida y sin formularios."
  pathname="/reservas"
>
  <section class="section-shell py-20 sm:py-24">
    <div
      class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[1fr_0.85fr] lg:items-stretch"
    >
      <div
        class="panel flex flex-col justify-between gap-8"
        data-aos="fade-right"
      >
        <div>
          <p class="eyebrow">Reservas fáciles</p>
          <h1 class="mt-3 font-display text-5xl text-text sm:text-6xl">
            Tu mesa en Venta Mirabueno, en un solo clic.
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-text/72">
            Sin formularios ni esperas innecesarias. Escríbenos por WhatsApp y
            te confirmaremos disponibilidad lo antes posible.
          </p>
        </div>

        <div class="space-y-5">
          <a
            href={whatsappUrl}
            class="btn-primary w-full justify-center text-center text-base"
            target="_blank"
            rel="noreferrer"
          >
            Abrir WhatsApp y reservar
          </a>
          <p class="text-sm uppercase tracking-[0.25em] text-text/55">
            Mensaje predefinido: “{SITE.whatsappMessage}”
          </p>
        </div>
      </div>

      <div class="space-y-6" data-aos="fade-left">
        <article class="panel">
          <SectionHeading
            eyebrow="Cómo funciona"
            title="Reserva directa y pensada para convertir."
            description="Comparte fecha, hora y número de comensales para agilizar la confirmación."
          />
        </article>

        <div class="grid gap-4">
          {
            [
              "Indícanos el día y la franja horaria que prefieres.",
              "Añade cuántas personas sois y cualquier detalle importante.",
              "Te confirmaremos la disponibilidad por el mismo canal.",
            ].map((step, index) => (
              <article class="rounded-[1.75rem] border border-black/8 bg-surface-soft p-6">
                <span class="text-sm uppercase tracking-[0.35em] text-primary">
                  Paso {index + 1}
                </span>
                <p class="mt-3 text-text/72">{step}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
