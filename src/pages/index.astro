---
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, phoneUrl, whatsappUrl } from "../consts";

const featuredDishes = [
  {
    title: "Crujientes de queso de cabra",
    description:
      "Crujiente relleno de queso de cabra con mermelada, uno de los entrantes más reconocibles de la casa.",
    price: "13 €",
  },
  {
    title: "Risotto de boletus",
    description:
      "Arroz meloso con boletus y queso grana padano, con un perfil cremoso y profundo.",
    price: "13 €",
  },
  {
    title: "Presa ibérica cubierta de jamón ibérico",
    description:
      "Una de las carnes estrella de la carta, intensa y jugosa, pensada para quien viene buscando producto ibérico.",
    price: "19,50 €",
  },
];

const galleryImages = [
  "https://www.guiarepsol.com/content/dam/repsol-guia/guia-cf/restaurante/imagenes/media-filer_public-56-9e-569eeefb-65be-4398-a3f4-9d3cef43e9a0-20060-venta-mirabueno-f2f860d1a7524f11b4850bf4d538735c.jpeg",
  "https://www.guiarepsol.com/content/dam/repsol-guia/guia-cf/restaurante/imagenes/media-filer_public-02-f9-02f99c70-3dea-43c4-88d2-63814f77f01e-20060-venta-mirabueno-0ac31fafb11b4c73922a2daa5a199026.jpeg",
  "https://www.guiarepsol.com/content/dam/repsol-guia/guia-cf/restaurante/imagenes/media-filer_public-f4-fb-f4fb8fd1-1690-4b24-82a6-cbe5c4551a9c-20060-venta-mirabueno-e5ed3756a6734c3e94dfe569d36cd7c5.jpeg",
  "https://www.guiarepsol.com/content/dam/repsol-guia/guia-cf/restaurante/imagenes/media-filer_public-19-e4-19e49abf-4672-492f-bfe9-a6c1462bb3a4-20060-venta-mirabueno-2eecb8f7dd144d5893522cc06884d400.jpeg",
];
---

<BaseLayout
  title="Restaurante Venta Mirabueno | Reserva una experiencia gastronómica premium en Setenil de las Bodegas"
  description="Descubre Venta Mirabueno, restaurante premium en Setenil de las Bodegas con cocina mediterránea de autor, carta selecta y reservas rápidas por WhatsApp."
  pathname="/"
>
  <Hero
    title="La mesa donde la cocina mediterránea se convierte en experiencia."
    description="Sabores honestos, producto cuidado y una atmósfera elegante para disfrutar de comidas y cenas memorables en el centro de Setenil de las Bodegas."
    primaryHref="/reservas"
    primaryLabel="Reservar ahora"
    secondaryHref="/carta"
    secondaryLabel="Ver carta"
    image="https://www.guiarepsol.com/content/dam/repsol-guia/guia-cf/restaurante/imagenes/media-filer_public-56-9e-569eeefb-65be-4398-a3f4-9d3cef43e9a0-20060-venta-mirabueno-f2f860d1a7524f11b4850bf4d538735c.jpeg"
  />

  <section
    class="section-shell grid gap-12 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:items-center"
  >
    <div data-aos="fade-right">
      <SectionHeading
        eyebrow="Sobre nosotros"
        title="Cocina con carácter, servicio cercano y un ambiente que invita a quedarse."
        description="En Venta Mirabueno reinterpretamos la tradición mediterránea con una puesta en escena contemporánea, ingredientes de temporada y una atención pensada para ocasiones especiales y encuentros cotidianos."
      />
    </div>

    <div class="grid gap-5 sm:grid-cols-2" data-aos="fade-left">
      <article class="panel">
        <span class="text-sm uppercase tracking-[0.3em] text-primary-light"
          >Producto</span
        >
        <h3 class="mt-4 font-display text-2xl text-text">Selección diaria</h3>
        <p class="mt-3 text-text/70">
          Materia prima fresca y una carta que evoluciona con el ritmo de la
          temporada.
        </p>
      </article>
      <article class="panel">
        <span class="text-sm uppercase tracking-[0.3em] text-primary-light"
          >Ambiente</span
        >
        <h3 class="mt-4 font-display text-2xl text-text">Espacio elegante</h3>
        <p class="mt-3 text-text/70">
          Luz tenue, diseño sofisticado y mesas pensadas para una velada cómoda.
        </p>
      </article>
      <article class="panel sm:col-span-2">
        <div
          class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
        >
          <div>
            <span class="text-sm uppercase tracking-[0.3em] text-primary-light"
              >Reserva directa</span
            >
            <h3 class="mt-4 font-display text-2xl text-text">
              Confirmación rápida por WhatsApp
            </h3>
          </div>
          <a
            href={whatsappUrl}
            class="btn-secondary"
            target="_blank"
            rel="noreferrer">Solicitar mesa</a
          >
        </div>
      </article>
    </div>
  </section>

  <section class="section-shell py-20">
    <div
      class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between"
    >
      <SectionHeading
        eyebrow="Carta destacada"
        title="Una selección pensada para abrir el apetito."
        description="Consulta nuestra propuesta gastronómica y descubre algunos de los platos favoritos de nuestros clientes."
      />
      <a href="/carta" class="btn-secondary w-full justify-center sm:w-auto"
        >Consulta nuestra carta</a
      >
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        featuredDishes.map((dish, index) => (
          <article
            class="panel"
            data-aos="fade-up"
            data-aos-delay={index * 120}
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class="font-display text-2xl text-text">{dish.title}</h3>
              <span class="shrink-0 whitespace-nowrap rounded-full border border-primary/20 bg-primary/8 px-3 py-1 text-sm text-primary">
                {dish.price}
              </span>
            </div>
            <p class="mt-4 text-text/70">{dish.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-shell py-20">
    <SectionHeading
      eyebrow="Galería"
      title="El entorno acompaña cada plato."
      description="Espacios cuidados, emplatados con detalle y una experiencia visual a la altura de la cocina."
      align="center"
    />

    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        galleryImages.map((image, index) => (
          <figure
            class="group overflow-hidden rounded-4xl border border-black/8 bg-white/80 shadow-wine"
            data-aos="zoom-in"
            data-aos-delay={index * 100}
          >
            <img
              src={image}
              alt={`Ambiente gastronómico en Venta Mirabueno ${index + 1}`}
              class="h-80 w-full object-cover transition duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </figure>
        ))
      }
    </div>
  </section>

  <section class="section-shell py-20">
    <div class="panel overflow-hidden">
      <div
        class="absolute inset-y-0 right-0 hidden w-1/2 bg-[radial-gradient(circle_at_center,rgba(95,34,33,0.35),transparent_70%)] lg:block"
      >
      </div>
      <div
        class="relative grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center"
      >
        <div data-aos="fade-right">
          <p class="eyebrow">Reserva tu mesa</p>
          <h2 class="mt-3 font-display text-4xl text-text sm:text-5xl">
            Haz tu reserva en segundos y vive Venta Mirabueno.
          </h2>
          <p class="mt-5 max-w-2xl text-lg text-text/70">
            Ideal para cenas especiales, reuniones o una escapada gastronómica
            en Setenil de las Bodegas. Atendemos tus reservas de forma rápida y
            cercana.
          </p>
        </div>
        <div class="flex flex-col gap-4 lg:items-start" data-aos="fade-left">
          <a
            href="/reservas"
            class="btn-primary justify-center lg:justify-start"
            >Reservar por WhatsApp</a
          >
          <a
            href={`tel:${phoneUrl}`}
            class="text-sm uppercase tracking-[0.3em] text-text/60 transition hover:text-primary-light"
          >
            {SITE.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
