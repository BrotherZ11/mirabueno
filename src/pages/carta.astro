---
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, whatsappUrl } from "../consts";
---

<BaseLayout
  title="Carta | Mirabueno Setenil"
  description="Consulta la carta de Mirabueno Casa de Comidas Setenil y descubre nuestra propuesta mediterránea premium en Setenil de las Bodegas."
  pathname="/carta"
>
  <section class="section-shell py-14 sm:py-24">
    <SectionHeading
      eyebrow="Consulta nuestra carta"
      title="Descubre nuestra propuesta gastronómica completa."
      description="Explora nuestra carta online y encuentra entrantes, principales y sugerencias para disfrutar de la experiencia Mirabueno."
      align="center"
    />

    <div class="mx-auto mt-10 max-w-6xl space-y-5 sm:mt-12 sm:space-y-6">
      <div
        class="flex flex-col gap-4 rounded-[1.75rem] border border-primary/15 bg-primary/6 p-5 text-center text-text/72 sm:rounded-4xl sm:p-6 md:flex-row md:items-center md:justify-between md:text-left"
      >
        <p>
          Consulta nuestra carta actualizada y, si quieres asegurar tu mesa
          antes de venir, reserva directamente por WhatsApp.
        </p>
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href={SITE.menuUrl}
            class="btn-primary justify-center"
            target="_blank"
            rel="noreferrer">Abrir carta</a
          >
          <a
            href={whatsappUrl}
            class="btn-secondary justify-center"
            target="_blank"
            rel="noreferrer">Reservar mesa</a
          >
        </div>
      </div>

      <div
        class="overflow-hidden rounded-4xl border border-black/8 bg-white shadow-wine"
        data-aos="fade-up"
        data-consent-iframe
        data-iframe-src={SITE.menuUrl}
        data-iframe-title="Carta online de Mirabueno Casa de Comidas"
      >
        <div
          class="flex h-[68vh] min-h-136 w-full flex-col items-center justify-center gap-4 p-6 text-center text-text/72 sm:h-[78vh] sm:min-h-180"
        >
          <p class="eyebrow">Contenido bloqueado hasta consentimiento</p>
          <h2 class="font-display text-2xl text-text">
            Activa cookies para ver la carta online
          </h2>
          <p class="max-w-lg text-sm leading-7 sm:text-base">
            La carta se muestra mediante un servicio externo que puede utilizar
            tecnologías de seguimiento. Solo se cargará si aceptas cookies de
            terceros.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <button
              type="button"
              class="btn-primary w-full justify-center sm:w-auto"
              data-consent-iframe-accept
            >
              Aceptar y ver carta
            </button>
            <a
              href="/politica-de-cookies"
              class="btn-secondary w-full justify-center sm:w-auto"
            >
              Más información
            </a>
          </div>
        </div>
      </div>

      <noscript>
        <div
          class="overflow-hidden rounded-4xl border border-black/8 bg-white shadow-wine"
        >
          <iframe
            src={SITE.menuUrl}
            title="Carta online de Mirabueno Casa de Comidas"
            class="h-[68vh] min-h-136 w-full sm:h-[78vh] sm:min-h-180"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"></iframe>
        </div>
      </noscript>
    </div>
  </section>

  <script>
    const consentKey = "mirabueno-cookie-consent";

    const mountIframe = (container: Element) => {
      if (
        !(container instanceof HTMLElement) ||
        container.dataset.loaded === "true"
      ) {
        return;
      }

      const iframe = document.createElement("iframe");
      iframe.src = container.dataset.iframeSrc ?? "";
      iframe.title = container.dataset.iframeTitle ?? "Contenido externo";
      iframe.className = "h-[68vh] min-h-136 w-full sm:h-[78vh] sm:min-h-180";
      iframe.loading = "lazy";
      iframe.referrerPolicy = "strict-origin-when-cross-origin";

      container.innerHTML = "";
      container.appendChild(iframe);
      container.dataset.loaded = "true";
    };

    const syncConsentIframes = (value: string | null) => {
      document.querySelectorAll("[data-consent-iframe]").forEach((el) => {
        if (value === "accepted") {
          mountIframe(el);
        }
      });
    };

    document
      .querySelectorAll("[data-consent-iframe-accept]")
      .forEach((button) => {
        button.addEventListener("click", () => {
          window.dispatchEvent(
            new CustomEvent("mirabueno:set-cookie-consent", {
              detail: { value: "accepted" },
            }),
          );
        });
      });

    syncConsentIframes(window.localStorage.getItem(consentKey));

    window.addEventListener("mirabueno:cookie-consent", ((event: Event) => {
      if (event instanceof CustomEvent) {
        syncConsentIframes(event.detail?.value);
      }
    }) as EventListener);
  </script>
</BaseLayout>
