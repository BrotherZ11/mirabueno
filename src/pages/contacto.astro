---
import SectionHeading from "../components/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, formattedAddress, phoneUrl, whatsappUrl } from "../consts";
---

<BaseLayout
  title="Contacto | Mirabueno Casa de Comidas"
  description="Encuentra la dirección, horario, teléfono y ubicación de Mirabueno Casa de Comidas en Setenil de las Bodegas."
  pathname="/contacto"
>
  <section class="section-shell py-14 sm:py-24">
    <SectionHeading
      eyebrow="Contacto"
      title="Ven a descubrir Mirabueno Casa de Comidas en el corazón de Setenil de las Bodegas."
      description="Te esperamos en un espacio elegante, perfecto para comidas, cenas y encuentros especiales."
      align="center"
    />

    <div
      class="mt-10 grid gap-5 sm:mt-12 sm:gap-6 lg:grid-cols-[0.95fr_1.05fr]"
    >
      <div class="grid gap-6" data-aos="fade-right">
        <article class="panel">
          <h2 class="font-display text-xl text-text sm:text-2xl">Dirección</h2>
          <p class="mt-4 text-text/72">{formattedAddress}</p>
        </article>

        <article class="panel">
          <h2 class="font-display text-xl text-text sm:text-2xl">Teléfono</h2>
          <p class="mt-4 text-text/72">
            <a
              href={`tel:${phoneUrl}`}
              class="transition hover:text-primary-light">{SITE.phone}</a
            >
          </p>
        </article>

        <article class="panel">
          <h2 class="font-display text-xl text-text sm:text-2xl">Horarios</h2>
          <ul class="mt-4 space-y-3 text-text/72">
            {
              SITE.hours.map((slot) => (
                <li class="flex flex-col gap-1 border-b border-black/8 pb-3 last:border-b-0 last:pb-0 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
                  <span class="text-text">{slot.label}</span>
                  <span>{slot.value}</span>
                </li>
              ))
            }
          </ul>
        </article>

        <a
          href={whatsappUrl}
          class="btn-primary justify-center"
          target="_blank"
          rel="noreferrer">Reservar por WhatsApp</a
        >
      </div>

      <div
        class="overflow-hidden rounded-4xl border border-black/8 bg-white shadow-wine"
        data-aos="fade-left"
      >
        <iframe
          src={SITE.mapEmbedUrl}
          title="Mapa de Mirabueno Casa de Comidas en Setenil de las Bodegas"
          class="h-88 w-full sm:h-full sm:min-h-145"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
