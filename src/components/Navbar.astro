---
import Icon from "../assets/Icon.png";
import { navLinks, whatsappUrl } from "../consts";

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-black/8 bg-background/90 backdrop-blur-xl"
>
  <div class="section-shell flex items-center justify-between gap-3 py-3 sm:gap-6 sm:py-4">
    <a
      href="/"
      class="min-w-0 flex items-center gap-2 text-sm tracking-[0.22em] text-text sm:gap-3 sm:tracking-[0.3em]"
      aria-label="Ir a la página principal de Venta Mirabueno"
    >
      <span
        class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-full border border-primary/20 bg-white shadow-sm sm:h-11 sm:w-11"
      >
        <img
          src={Icon.src}
          alt="Logo de Venta Mirabueno"
          class="h-full w-full object-cover"
          width="44"
          height="44"
        />
      </span>
      <span class="min-w-0">
        <span class="block truncate font-display text-base tracking-[0.08em] sm:text-xl sm:tracking-[0.12em]"
          >Venta Mirabueno</span
        >
        <span class="block truncate text-[0.62rem] uppercase tracking-[0.18em] text-text/55 sm:text-xs sm:tracking-[0.35em]"
          >Setenil de las Bodegas · España</span
        >
      </span>
    </a>

    <nav
      class="hidden items-center gap-8 md:flex"
      aria-label="Navegación principal"
    >
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <a
              href={link.href}
              class:list={[
                "text-sm uppercase tracking-[0.25em] transition duration-300 hover:text-primary-light",
                isActive ? "text-primary" : "text-text/70",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden md:block">
      <a href={whatsappUrl} class="btn-primary" target="_blank" rel="noreferrer"
        >Reservar</a
      >
    </div>

    <button
      id="nav-toggle"
      class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-black/10 bg-white/80 text-text md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
      type="button"
    >
      <span class="sr-only">Abrir menú</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
      >
        <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-black/8 bg-background/95 md:hidden"
  >
    <nav
      class="section-shell flex flex-col gap-3 py-4"
      aria-label="Navegación móvil"
    >
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <a
              href={link.href}
              class:list={[
                "rounded-2xl border px-4 py-3 text-center text-[0.72rem] uppercase tracking-[0.18em] transition duration-300",
                isActive
                  ? "border-primary/30 bg-primary/8 text-primary"
                  : "border-black/10 bg-white/80 text-text/75 hover:border-primary/30 hover:text-text",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
      <a
        href={whatsappUrl}
        class="btn-primary w-full justify-center text-center"
        target="_blank"
        rel="noreferrer">Reservar por WhatsApp</a
      >
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector("#nav-toggle");
  const menu = document.querySelector("#mobile-menu");

  if (toggle instanceof HTMLButtonElement && menu instanceof HTMLElement) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden");
    });
  }
</script>
