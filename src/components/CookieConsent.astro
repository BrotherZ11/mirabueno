<div class="fixed inset-x-4 bottom-4 z-80 hidden" data-cookie-banner hidden>
  <div
    class="mx-auto max-w-3xl rounded-[1.75rem] border border-black/8 bg-surface p-5 shadow-wine sm:p-6"
  >
    <div class="flex flex-col gap-4">
      <div>
        <p class="eyebrow">Consentimiento de cookies</p>
        <h2 class="mt-3 font-display text-xl text-text sm:text-2xl">
          Decide si quieres activar el mapa y la analítica.
        </h2>
        <p class="mt-3 text-sm leading-7 text-text/72 sm:text-base">
          Usamos servicios de terceros solo si los aceptas. El rechazo mantiene
          la web operativa, pero sin mapa embebido ni analítica de Vercel.
        </p>
      </div>

      <div
        class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
      >
        <a
          href="/politica-de-cookies"
          class="text-sm font-semibold text-primary hover:text-primary-light"
        >
          Leer política de cookies
        </a>

        <div class="flex flex-col gap-3 sm:flex-row">
          <button
            type="button"
            class="btn-secondary w-full justify-center sm:w-auto"
            data-cookie-reject
          >
            Rechazar
          </button>
          <button
            type="button"
            class="btn-primary w-full justify-center sm:w-auto"
            data-cookie-accept
          >
            Aceptar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const cookieConsentKey = "mirabueno-cookie-consent";
  type ConsentValue = "accepted" | "rejected";

  const banner = document.querySelector("[data-cookie-banner]");
  const acceptButton = document.querySelector("[data-cookie-accept]");
  const rejectButton = document.querySelector("[data-cookie-reject]");

  const showBanner = () => {
    if (banner instanceof HTMLElement) {
      banner.hidden = false;
      banner.classList.remove("hidden");
    }
  };

  const hideBanner = () => {
    if (banner instanceof HTMLElement) {
      banner.hidden = true;
      banner.classList.add("hidden");
    }
  };

  const emitConsent = (value: ConsentValue) => {
    window.dispatchEvent(
      new CustomEvent("mirabueno:set-cookie-consent", {
        detail: { value },
      }),
    );
  };

  const syncBanner = () => {
    const storedConsent = window.localStorage.getItem(cookieConsentKey);
    if (storedConsent === "accepted" || storedConsent === "rejected") {
      hideBanner();
      return;
    }

    showBanner();
  };

  acceptButton?.addEventListener("click", () => emitConsent("accepted"));
  rejectButton?.addEventListener("click", () => emitConsent("rejected"));

  window.addEventListener("mirabueno:cookie-consent", syncBanner);
  window.addEventListener("mirabueno:open-cookie-settings", showBanner);

  syncBanner();
</script>
