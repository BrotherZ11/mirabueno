<div class="fixed inset-x-4 bottom-4 z-80 hidden" data-cookie-banner hidden>
  <div
    class="mx-auto max-w-3xl rounded-[1.75rem] border border-black/8 bg-surface p-5 shadow-wine sm:p-6"
  >
    <div class="flex flex-col gap-4">
      <div>
        <p class="eyebrow">Tu privacidad</p>
        <h2 class="mt-3 font-display text-xl text-text sm:text-2xl">
          Elige que quieres activar.
        </h2>
        <p class="mt-3 text-sm leading-7 text-text/72 sm:text-base">
          Puedes decidir por separado si quieres permitir la analitica y los
          servicios de terceros, como el mapa. La web seguira funcionando aunque
          no los actives.
        </p>
      </div>

      <div class="grid gap-3" role="group" aria-label="Preferencias de cookies">
        <div class="rounded-3xl border border-black/8 bg-background/55 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-display text-lg text-text">Cookies necesarias</h3>
              <p class="mt-1 text-sm leading-6 text-text/70">
                Siempre activas para recordar tu eleccion y mantener la web
                operativa.
              </p>
            </div>
            <span
              class="rounded-full border border-primary/20 bg-primary/8 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-primary"
            >
              Siempre activas
            </span>
          </div>
        </div>

        <label
          class="flex items-start justify-between gap-4 rounded-3xl border border-black/8 bg-background/55 p-4"
          for="cookie-analytics-toggle"
        >
          <div>
            <span class="block font-display text-lg text-text">Analitica</span>
            <span class="mt-1 block text-sm leading-6 text-text/70">
              Nos ayuda a entender de forma anonima como se usa la web para
              mejorarla.
            </span>
          </div>
          <input
            id="cookie-analytics-toggle"
            type="checkbox"
            class="mt-1 h-5 w-5 shrink-0 accent-primary"
            data-cookie-analytics
          />
        </label>

        <label
          class="flex items-start justify-between gap-4 rounded-3xl border border-black/8 bg-background/55 p-4"
          for="cookie-third-party-toggle"
        >
          <div>
            <span class="block font-display text-lg text-text"
              >Servicios de terceros</span
            >
            <span class="mt-1 block text-sm leading-6 text-text/70">
              Permite cargar contenidos externos como Google Maps en la pagina
              de contacto.
            </span>
          </div>
          <input
            id="cookie-third-party-toggle"
            type="checkbox"
            class="mt-1 h-5 w-5 shrink-0 accent-primary"
            data-cookie-third-party
          />
        </label>
      </div>

      <div
        class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between"
      >
        <a
          href="/politica-de-cookies"
          class="text-sm font-semibold text-primary hover:text-primary-light"
        >
          Saber más sobre las cookies
        </a>

        <div
          class="flex flex-col gap-3 sm:flex-row sm:flex-wrap lg:justify-end"
        >
          <button
            type="button"
            class="btn-secondary w-full justify-center sm:w-auto"
            data-cookie-reject-all
          >
            Rechazar todo
          </button>
          <button
            type="button"
            class="btn-secondary w-full justify-center sm:w-auto"
            data-cookie-save
          >
            Guardar seleccion
          </button>
          <button
            type="button"
            class="btn-primary w-full justify-center sm:w-auto"
            data-cookie-accept-all
          >
            Aceptar todo
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const cookieConsentKey = "mirabueno-cookie-consent";
  type ConsentPreferences = {
    analytics: boolean;
    thirdParty: boolean;
  };

  const banner = document.querySelector("[data-cookie-banner]");
  const analyticsToggle = document.querySelector("[data-cookie-analytics]");
  const thirdPartyToggle = document.querySelector("[data-cookie-third-party]");
  const acceptAllButton = document.querySelector("[data-cookie-accept-all]");
  const rejectAllButton = document.querySelector("[data-cookie-reject-all]");
  const saveButton = document.querySelector("[data-cookie-save]");

  const defaultPreferences: ConsentPreferences = {
    analytics: false,
    thirdParty: false,
  };

  const isPreferences = (value: unknown): value is ConsentPreferences => {
    if (!value || typeof value !== "object") {
      return false;
    }

    const candidate = value as Record<string, unknown>;
    return (
      typeof candidate.analytics === "boolean" &&
      typeof candidate.thirdParty === "boolean"
    );
  };

  const parseStoredConsent = (): ConsentPreferences | null => {
    const storedConsent = window.localStorage.getItem(cookieConsentKey);

    if (!storedConsent) {
      return null;
    }

    if (storedConsent === "accepted") {
      return { analytics: true, thirdParty: true };
    }

    if (storedConsent === "rejected") {
      return { analytics: false, thirdParty: false };
    }

    try {
      const parsed = JSON.parse(storedConsent) as unknown;
      return isPreferences(parsed) ? parsed : null;
    } catch {
      return null;
    }
  };

  const readFormPreferences = (): ConsentPreferences => ({
    analytics:
      analyticsToggle instanceof HTMLInputElement
        ? analyticsToggle.checked
        : defaultPreferences.analytics,
    thirdParty:
      thirdPartyToggle instanceof HTMLInputElement
        ? thirdPartyToggle.checked
        : defaultPreferences.thirdParty,
  });

  const syncForm = (preferences: ConsentPreferences) => {
    if (analyticsToggle instanceof HTMLInputElement) {
      analyticsToggle.checked = preferences.analytics;
    }

    if (thirdPartyToggle instanceof HTMLInputElement) {
      thirdPartyToggle.checked = preferences.thirdParty;
    }
  };

  const showBanner = () => {
    if (banner instanceof HTMLElement) {
      banner.hidden = false;
      banner.classList.remove("hidden");
    }
  };

  const hideBanner = () => {
    if (banner instanceof HTMLElement) {
      banner.hidden = true;
      banner.classList.add("hidden");
    }
  };

  const emitConsent = (preferences: ConsentPreferences) => {
    window.dispatchEvent(
      new CustomEvent("mirabueno:set-cookie-consent", {
        detail: { preferences },
      }),
    );
  };

  const syncBanner = () => {
    const storedConsent = parseStoredConsent();
    if (storedConsent) {
      syncForm(storedConsent);
      hideBanner();
      return;
    }

    syncForm(defaultPreferences);
    showBanner();
  };

  acceptAllButton?.addEventListener("click", () => {
    emitConsent({ analytics: true, thirdParty: true });
  });

  rejectAllButton?.addEventListener("click", () => {
    emitConsent({ analytics: false, thirdParty: false });
  });

  saveButton?.addEventListener("click", () => {
    emitConsent(readFormPreferences());
  });

  window.addEventListener("mirabueno:cookie-consent", syncBanner);
  window.addEventListener("mirabueno:open-cookie-settings", () => {
    syncForm(parseStoredConsent() ?? defaultPreferences);
    showBanner();
  });

  syncBanner();
</script>
