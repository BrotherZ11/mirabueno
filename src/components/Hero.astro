---
interface Props {
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  image: string;
  eyebrow?: string;
}

const {
  title,
  description,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  image,
  eyebrow = "Restaurante en Setenil de las Bodegas",
} = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0">
    <img
      src={image}
      alt="Interior elegante del restaurante Venta Mirabueno"
      class="h-full w-full object-cover"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(253,251,250,0.28),rgba(253,251,250,0.72))]"
    >
    </div>
    <div
      class="absolute inset-x-0 bottom-0 h-72 bg-[radial-gradient(circle_at_bottom,rgba(96,38,38,0.22),transparent_70%)]"
    >
    </div>
  </div>

  <div
    class="section-shell relative flex min-h-[88svh] items-center py-24 sm:py-32"
  >
    <div class="max-w-3xl space-y-8 rounded-[2rem] border border-white/70 bg-[#fdfbfa]/88 p-8 shadow-wine backdrop-blur-sm sm:p-10" data-aos="fade-up">
      <p class="eyebrow">{eyebrow}</p>
      <h1
        class="max-w-3xl font-display text-5xl leading-tight text-text sm:text-6xl lg:text-7xl"
      >
        {title}
      </h1>
      <p class="max-w-2xl text-lg text-text/72 sm:text-xl">
        {description}
      </p>
      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href={primaryHref}
          class="btn-primary justify-center sm:justify-start">{primaryLabel}</a
        >
        {
          secondaryHref && secondaryLabel && (
            <a
              href={secondaryHref}
              class="btn-secondary justify-center sm:justify-start"
            >
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>
