---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const isCenter = align === "center";
---

<div class:list={[isCenter ? "mx-auto max-w-3xl text-center" : "max-w-3xl"]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-3 font-display text-4xl text-text sm:text-5xl">{title}</h2>
  {description && <p class="mt-5 text-lg text-text/70">{description}</p>}
</div>
