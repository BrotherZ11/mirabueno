---
import {
  SITE,
  formattedAddress,
  legalLinks,
  navLinks,
  phoneUrl,
  socialLinks,
} from "../consts";
---

<footer class="border-t border-black/8 bg-white/70 backdrop-blur-sm">
  <div
    class="section-shell grid gap-8 py-10 sm:py-14 lg:grid-cols-[1.1fr_0.8fr_0.8fr_0.8fr]"
  >
    <div class="space-y-5">
      <p class="eyebrow">Restaurante en Setenil de las Bodegas</p>
      <h2 class="font-display text-2xl text-text sm:text-3xl">
        Una experiencia gastronómica cuidada al detalle.
      </h2>
      <p class="max-w-xl text-text/70">
        Cocina mediterránea de autor, ambiente elegante y una atención pensada
        para convertir cada visita en un momento especial.
      </p>
      <div>
        <h3 class="font-display text-lg text-text sm:text-xl">Síguenos</h3>
        <ul class="mt-4 flex flex-wrap gap-3 text-sm text-text/70" aria-label="Redes sociales">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={link.ariaLabel}
                  class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-surface text-text transition hover:border-primary/30 hover:text-primary-light"
                >
                  {
                    link.label === "Instagram" ? (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        class="h-5 w-5"
                        aria-hidden="true"
                      >
                        <rect x="3.75" y="3.75" width="16.5" height="16.5" rx="4.5"></rect>
                        <circle cx="12" cy="12" r="3.75"></circle>
                        <circle cx="17.25" cy="6.75" r="0.9" fill="currentColor" stroke="none"></circle>
                      </svg>
                    ) : (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="h-5 w-5"
                        aria-hidden="true"
                      >
                        <path d="M13.5 21v-7h2.35l.35-2.75H13.5V9.5c0-.8.22-1.35 1.37-1.35H16.3V5.7c-.25-.03-1.1-.1-2.08-.1-2.06 0-3.47 1.26-3.47 3.57v2.08H8.4V14h2.35v7h2.75Z"></path>
                      </svg>
                    )
                  }
                  <span class="sr-only">{link.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div>
      <h3 class="font-display text-xl text-text">Explora</h3>
      <ul class="mt-5 space-y-3 text-text/70">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="transition hover:text-primary-light">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="font-display text-xl text-text">Contacto</h3>
      <ul class="mt-5 space-y-3 text-text/70">
        <li>{formattedAddress}</li>
        <li>
          <a
            href={`tel:${phoneUrl}`}
            class="transition hover:text-primary-light">{SITE.phone}</a
          >
        </li>
        <li>
          {
            SITE.hours.map((slot) => (
              <span class="block">
                {slot.label}: {slot.value}
              </span>
            ))
          }
        </li>
      </ul>
    </div>

    <div>
      <h3 class="font-display text-xl text-text">Legal</h3>
      <ul class="mt-5 space-y-3 text-text/70">
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} class="transition hover:text-primary-light">
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <button
            type="button"
            class="text-left transition hover:text-primary-light"
            id="open-cookie-settings"
          >
            Configurar cookies
          </button>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-black/8">
    <p class="section-shell py-4 text-center text-sm text-text/70">
      © {new Date().getFullYear()}
      {SITE.legalName}. Todos los derechos reservados.
    </p>
  </div>
</footer>

<script>
  const openCookieSettings = document.querySelector("#open-cookie-settings");

  openCookieSettings?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("mirabueno:open-cookie-settings"));
  });
</script>
